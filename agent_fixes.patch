--- a/crates/tsspd/src/edge_cases_tests.rs
+++ b/crates/tsspd/src/edge_cases_tests.rs
@@ -78,8 +78,18 @@ mod edge_cases {
     }
 
     #[test]
-    fn folder_single_dot_allowed() {
-        // Single "." is allowed - it just means current directory
+    fn folder_dot_prefix_names_allowed() {
+        // Names that start with a dot (e.g. ".hidden") are not a traversal
+        // and must remain valid folder names.
         assert!(validate_folder_path("files/.current").is_ok());
     }
+
+    #[test]
+    fn folder_single_dot_component_rejected() {
+        // A bare "." component is semantically "current directory" and must be
+        // rejected to keep folder paths unambiguous.
+        assert!(validate_folder_path(".").is_err());
+        assert!(validate_folder_path("files/./secret").is_err());
+        assert!(validate_folder_path("./photos").is_err());
+    }
 }
